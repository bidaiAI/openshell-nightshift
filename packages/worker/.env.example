WORKER_ID=worker_proof_runner_3
WORKER_NAME=NightShift Worker
WORKER_AUTH_TOKEN=nightshift-worker-beta-token
WORKER_POLL_INTERVAL_MS=15000
WORKER_MAX_CONCURRENT_ASSIGNMENTS=1
WORKER_LOG_LEVEL=info
WORKER_SUPPORTED_CHAINS=midnight
WORKER_CAPABILITIES=local-execution,receipt-generation,model-adapter-routing
WORKER_SUPPORTED_TRANSPORTS=http-poller,libp2p
WORKER_MODEL_CATALOG_JSON=[{"provider":"mock","model":"local-sandbox","capabilities":["text","json","tool-calling"],"local":true,"pricingTier":"local"}]
